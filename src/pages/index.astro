---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Video Summary">
	<div class="flex h-screen items-center justify-center bg-gray-100 dark:bg-gray-900">
		<div class="text-center">
			<h1 class="mb-4 text-4xl font-bold text-gray-800 dark:text-white">
				Welcome to Video Summary
			</h1>
			<p class="mb-8 text-lg text-gray-600 dark:text-gray-400">
				Get summaries of your favorite videos in seconds.
			</p>
			<div class="space-x-4">
				<a
					href="/login"
					class="inline-block rounded-md bg-blue-600 px-6 py-3 font-medium text-white hover:bg-blue-700"
				>
					Sign In
				</a>
				<a
					href="/signup"
					class="inline-block rounded-md border border-gray-300 px-6 py-3 font-medium text-gray-700 hover:bg-gray-200 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800"
				>
					Sign Up
				</a>
			</div>
		</div>
	</div>
</Layout>
