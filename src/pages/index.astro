---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Video Summary" showNavigation={false}>
	<div class="min-h-screen bg-white dark:bg-gray-50">
		<!-- Hero Section -->
		<section class="relative overflow-hidden bg-white dark:bg-gray-50">
			<div class="absolute inset-0 bg-gradient-to-r from-blue-50/50 to-indigo-50/30"></div>
			<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
				<div class="text-center">
						<div class="mb-8">
						<div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 dark:bg-blue-50 rounded-2xl mb-6">
							<svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h1 class="text-4xl sm:text-6xl font-bold text-gray-900 mb-6">
							Video Summary
						</h1>
						<p class="text-xl sm:text-2xl text-gray-600 mb-8 max-w-3xl mx-auto">
							Get AI-powered summaries of your favorite YouTube videos in seconds. Perfect for personal use and staying informed without watching hours of content.
						</p>
					</div>

					<div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
						<a
							href="/signup"
							class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors duration-200"
						>
							<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
							</svg>
							Get Started Free
						</a>
						<a
							href="/login"
							class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-gray-700 bg-gray-100 border border-gray-200 rounded-lg hover:bg-gray-200 transition-colors duration-200"
						>
							<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
							</svg>
							Sign In
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Features Section -->
		<section class="py-24 bg-gray-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-16">
					<h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
						Why Choose Video Summary?
					</h2>
					<p class="text-xl text-gray-600 max-w-2xl mx-auto">
						Transform how you consume YouTube content with AI-powered insights. Perfect for personal use and efficient content consumption.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<!-- Feature 1 -->
					<div class="bg-white rounded-lg p-8 text-center border border-gray-200 hover:shadow-md transition-shadow duration-200">
						<div class="inline-flex items-center justify-center w-16 h-16 bg-blue-50 rounded-lg mb-6">
							<svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-gray-900 mb-4">AI-Powered Summaries</h3>
						<p class="text-gray-600">
							Get concise TL;DR and detailed summaries using advanced AI models. Never miss key insights from long videos.
						</p>
					</div>

					<!-- Feature 2 -->
					<div class="bg-white rounded-lg p-8 text-center border border-gray-200 hover:shadow-md transition-shadow duration-200">
						<div class="inline-flex items-center justify-center w-16 h-16 bg-blue-50 rounded-lg mb-6">
							<svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-gray-900 mb-4">YouTube Integration</h3>
						<p class="text-gray-600">
							Connect up to 10 YouTube channels and get automatic notifications about new videos from your favorites.
						</p>
					</div>

					<!-- Feature 3 -->
					<div class="bg-white rounded-lg p-8 text-center border border-gray-200 hover:shadow-md transition-shadow duration-200">
						<div class="inline-flex items-center justify-center w-16 h-16 bg-blue-50 rounded-lg mb-6">
							<svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-gray-900 mb-4">Daily Automation</h3>
						<p class="text-gray-600">
							Automatic daily summary generation for the latest videos. Stay updated without manual effort.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 bg-blue-600">
			<div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
				<h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
					Ready to Save Hours of Watching Time?
				</h2>
				<p class="text-xl text-blue-100 mb-10 max-w-2xl mx-auto">
					Take control of your YouTube consumption with AI-powered video summaries. Perfect for personal use and staying informed efficiently.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a
						href="/signup"
						class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-blue-600 bg-white rounded-lg hover:bg-gray-50 transition-colors duration-200"
					>
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
						Start Summarizing Now
					</a>
					<a
						href="/login"
						class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-lg hover:bg-white hover:text-blue-600 transition-colors duration-200"
					>
						Sign In to Continue
					</a>
				</div>
			</div>
		</section>

		<!-- Footer Disclaimer -->
		<section class="py-8 bg-white border-t border-gray-200">
			<div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
				<p class="text-sm text-gray-500">
					This tool is designed for personal use only. Please respect YouTube's Terms of Service and content creators' rights.
				</p>
			</div>
		</section>
	</div>
</Layout>
