---
import Layout from '@/layouts/Layout.astro';
import SummaryDetailsView from '@/components/views/SummaryDetailsView';

const { summaryId } = Astro.params;

if (!summaryId) {
  return new Response('Not found', { status: 404 });
}
---

<Layout title="Video Summary" showNavigation={true}>
	<SummaryDetailsView client:only="react" summaryId={summaryId} />
</Layout>
